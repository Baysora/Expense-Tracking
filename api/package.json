{
  "name": "@expense/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "ts-node --transpile-only -r tsconfig-paths/register src/localServer.ts",
    "watch": "concurrently \"tsc -w\" \"func start --verbose\""
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/storage-blob": "^12.24.0",
    "@prisma/client": "^5.22.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  }
}
