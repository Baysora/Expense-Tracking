generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model OpCo {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  isHoldCo  Boolean  @default(false)
  requireAttachmentForAll      Boolean  @default(false)
  requireAttachmentAboveAmount Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  categories  ExpenseCategory[]
  departments Department[]
  expenses    Expense[]
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  role               String
  passwordHash       String
  mustChangePassword Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  opCoId String?
  opCo   OpCo?   @relation(fields: [opCoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  submittedExpenses Expense[]        @relation("SubmittedBy")
  approvalRecords   ApprovalRecord[]
}

model ExpenseCategory {
  id                 String  @id @default(cuid())
  name               String
  status             String  @default("ACTIVE")
  isShared           Boolean @default(false)
  requiresAttachment Boolean @default(false)

  opCoId   String
  opCo     OpCo      @relation(fields: [opCoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expenses Expense[]

  @@unique([opCoId, name])
}

model Department {
  id     String @id @default(cuid())
  name   String
  status String @default("ACTIVE")

  opCoId   String
  opCo     OpCo      @relation(fields: [opCoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expenses Expense[]

  @@unique([opCoId, name])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  project String?

  submittedById String
  submittedBy   User   @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  opCoId String
  opCo   OpCo   @relation(fields: [opCoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  attachments     ExpenseAttachment[]
  approvalRecords ApprovalRecord[]

  @@index([opCoId, status])
  @@index([submittedById])
}

model ExpenseAttachment {
  id         String   @id @default(cuid())
  type       String
  fileName   String
  blobName   String
  mimeType   String
  sizeBytes  Int
  uploadedAt DateTime @default(now())

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ApprovalRecord {
  id        String   @id @default(cuid())
  action    String
  comment   String?
  createdAt DateTime @default(now())

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  reviewedById String
  reviewedBy   User   @relation(fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
